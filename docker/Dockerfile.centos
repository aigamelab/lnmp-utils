FROM quay.io/centos/centos:stream9

# Minimal build environment; component install scripts handle their own deps
RUN dnf install -y --setopt=install_weak_deps=False --allowerasing \
    procps-ng \
    curl \
    git \
    gcc \
    gcc-c++ \
    make \
    wget \
    perl \
    tar \
    gzip \
    bzip2 \
    cmake \
    && dnf clean all

WORKDIR /opt/lnmp-utils

COPY install.sh func_init.sh func_install.sh init_rhel.sh init_debian.sh ./
COPY install ./
COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

ENTRYPOINT ["/entrypoint.sh"]
