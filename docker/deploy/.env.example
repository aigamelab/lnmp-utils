# lnmp-utils deployment configuration
# Copy to .env and edit as needed: cp .env.example .env

# Which services to start (preset or comma-separated list)
# Presets: lnmp | full | minimal | nosql
# Custom:  php,mariadb,openresty,redis,memcached,mongodb,node,fastdfs
LNMP_COMPONENTS=lnmp

# Base distribution image: rockylinux | debian | ubuntu | centos
LNMP_DISTRO=debian

# Port mappings (host:container)
HOST_PORT_WWW=80
HOST_PORT_DB=3306
HOST_PORT_REDIS=6379
HOST_PORT_MEMCACHED=11211
HOST_PORT_MONGO=27017

# Persistent data directory (relative to docker-compose.yml or absolute path)
# On macOS/Windows, use a path under your home directory for best performance
DATA_DIR=./docker-fs

# Container memory limit
MEMORY_LIMIT=4g
